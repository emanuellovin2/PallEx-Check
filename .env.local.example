# ============================================================
#  PallEx Check — Variabile de Mediu
#  Copiază acest fișier ca: .env.local
#  Nu comite niciodată .env.local în git!
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Unde găsești: https://supabase.com/dashboard
#   → Selectează proiectul → Project Settings → API

# URL-ul proiectului tău Supabase (public, safe pentru browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Cheia anonimă — publică, folosită pentru autentificare și RLS
# Secțiunea: Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Cheia Service Role — PRIVATĂ, EXCLUSIV SERVER-SIDE
# NU o expune niciodată în browser sau în cod client!
# Secțiunea: Project API keys → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
